# Anthropic (Phase 2+)
ANTHROPIC_API_KEY=sk-ant-...

# Market data (Phase 3+)
TRADIER_API_TOKEN=
TRADIER_API_BASE=https://api.tradier.com/v1
MENTHORQ_API_KEY=
MENTHORQ_API_BASE=https://api.menthorq.com/v1
